{
  "manifest_version": 3,
  "name": "Bio_Vault",
  "version": "2.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "models/*",
        "face-api.min.js",
        "HomePage.html",
        "HomePage.js",
        "camera.html",
        "camera.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}